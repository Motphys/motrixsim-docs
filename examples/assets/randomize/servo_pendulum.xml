<mujoco model="servo_pendulum">
    <include file="../common/materials.xml" />
    <compiler angle="radian" />
    <option timestep="0.005" />
    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.01" type="plane" material="motphys-ground" />
        <body name="pivot" pos="0 0 2">
            <geom type="sphere" size="0.07" rgba="0.5 0.5 0.5 1" />
            <body name="pendulum">
                <joint name="hinge" type="hinge" axis="0 1 0" />
                <geom type="capsule" size="0.05 0.5" pos="0 0 -0.5" rgba="0.7 0.5 0.2 1" />
                <geom type="sphere" size="0.15" pos="0 0 -1.1" rgba="0.2 0.4 0.8 1" />
            </body>
        </body>
    </worldbody>
    <actuator>
        <position name="servo" joint="hinge" kp="40" kv="5" />
    </actuator>
</mujoco>
