<mujoco model="infinite_floor_plane" >
  <compiler angle="radian" autolimits="true"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="125" elevation="-25"/>
  </visual>

  <asset>
    <!-- 天空盒纹理保留（可选，合并时若主场景有天空盒会自动覆盖） -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
      height="3072" />
    <!-- 地面纹理 -->
    <texture type="2d" name="groundplane" file="../../../common/motphys-ground.png"
             width="1024" height="1024"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="0.1 0.1"
      reflectance="0.2" rgba="0.7 0.7 0.7 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3.5" dir="-1 0 -1" directional="true" />
    <geom name="infinite_floor" size="0 0 0.05" pos="0 0 0" type="plane"
          material="groundplane" rgba="0.8 0.8 0.8 1" />
  </worldbody>
</mujoco>
