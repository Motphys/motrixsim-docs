
<mujoco model="R_wheel">
  <compiler angle="radian" assetdir="assets" autolimits="true"/>

  <!-- 加载视觉和碰撞模型作为资源 -->
  <asset>
    <model name="visual_R_wheel" file="V_R_wheel.xml"/>
    <model name="collision_R_wheel" file="C_R_wheel.xml"/>
  </asset>

  <worldbody>
    <body name="R_wheel" pos="0 0 0">
      <!-- 自由关节 -->

      <!-- 附加碰撞模型 -->
      <body name="collision_anchor">
        <attach model="collision_R_wheel" prefix="collision_"/>
      </body>

      <!-- 附加视觉模型 -->
      <body name="visual_anchor">
        <attach model="visual_R_wheel" prefix="visual_"/>
      </body>
    </body>
  </worldbody>
</mujoco>