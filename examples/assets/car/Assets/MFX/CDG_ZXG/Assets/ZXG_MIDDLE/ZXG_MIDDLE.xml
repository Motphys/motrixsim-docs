
<mujoco model="ZXG_MIDDLE">
  <compiler angle="radian" assetdir="assets" autolimits="true"/>

  <!-- 加载视觉和碰撞模型作为资源 -->
  <asset>
    <model name="visual_ZXG_MIDDLE" file="V_ZXG_MIDDLE.xml"/>
    <model name="collision_ZXG_MIDDLE" file="C_ZXG_MIDDLE.xml"/>
  </asset>

  <worldbody>
    <body name="ZXG_MIDDLE" pos="0 0 0">

      <!-- 附加碰撞模型 -->
      <body name="collision_anchor">
        <attach model="collision_ZXG_MIDDLE" prefix="collision_"/>
      </body>

      <!-- 附加视觉模型 -->
      <body name="visual_anchor">
        <attach model="visual_ZXG_MIDDLE" prefix="visual_"/>
      </body>
    </body>
  </worldbody>
</mujoco>