
<mujoco model="JZTH">
  <compiler angle="radian" assetdir="assets" autolimits="true"/>

  <!-- 加载视觉和碰撞模型作为资源 -->
  <asset>
    <model name="visual_JZTH" file="V_JZTH.xml"/>
    <model name="collision_JZTH" file="C_JZTH.xml"/>
  </asset>

  <worldbody>
    <body name="JZTH" pos="0 0 0">

      <!-- 附加碰撞模型 -->
      <!-- <body name="collision_anchor">
        <attach model="collision_JZTH" prefix="c_"/>
      </body> -->

      <!-- 附加视觉模型 -->
      <body name="visual_anchor">
        <attach model="visual_JZTH" prefix="v_"/>
      </body>
    </body>
  </worldbody>
</mujoco>