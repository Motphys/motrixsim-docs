<mujoco>
    <include file="common/materials.xml" />
    <option timestep="0.01" iterations="100" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <global azimuth="-130" elevation="-20"/>
    </visual>

    <asset>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.4314 0.5294 0.6431" rgb2="0.8157 0.8549 0.9059"
        markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="1 1" reflectance="0.2"/>
        <texture type="2d" name="cylinder_checker" builtin="checker" mark="edge"
                 rgb1="1 1 1" rgb2="0.8 0.1 0.1" markrgb="0.5 0.5 0.5"
                 width="200" height="200"/>
        <material name="cylinder_mat" texture="cylinder_checker" texrepeat="4 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

        <!-- Ground plane -->
        <geom name="floor" pos="0 0 -1" size="0 0 0.01" type="plane" material="motphys-ground" />

        <!-- Inclined plane (slope) - 30 degree angle -->
        <geom name="slope" type="box" size="2 0.05 2" rgba="0.7 0.7 0.7 1" euler="80 0 0" pos="0 0 0"/>

        <!-- Cylinder that will roll down the slope -->
        <!-- Positioned at the top of the slope -->
        <body name="cylinder" pos="0 -1 1.2" euler="0 90 0">
            <!-- Free joint allows full 6DOF motion -->
            <freejoint />
            <!-- Cylinder geometry: radius 0.3, height 0.5 -->
            <!-- Size is (radius, half_height) -->
            <geom name="cylinder_geom" type="cylinder" size="0.3 0.1" material="cylinder_mat" rgba="0.8588 0.6941 0.302 1"
                contype="1" conaffinity="1" priority="1" friction="0.8 0.005 0.0001" />
        </body>
    </worldbody>
</mujoco>
