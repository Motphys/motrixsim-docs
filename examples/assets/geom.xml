<mujoco>
  <include file="./common/materials.xml"/>
  <option timestep="0.01"/>
  <default>
    <default class="mesh_v">
      <geom type="mesh"/>
    </default>
  </default>
  <asset>
    <texture name="file_plane" type="2d" builtin="checker" width="128" height="128" rgb1="0.5 0.4 0.3" rgb2="0.6 0.5 0.4"/>
    <material name="file_plane" texture="file_plane" texrepeat="4 4" texuniform="true"/>
    <hfield name="file_terrain" file = "common/terrain.hfield" content_type ="hfield" size="5 5 2 1"/>
    <mesh class="mesh_v" name="m1" file="go1/assets/trunk.stl"/>
  </asset>
  <worldbody>
    <light name="light" pos="0 0 3" type="directional"/>
    <camera name="fixed" pos="0 -3 3" xyaxes="1 0 0 0 1 1"/>
    <geom name="floor" type="plane" size="0 0 0.1" pos="0 0 0" rgba="0.4 0.4 0.4 1" material="motphys-ground"/>
    <geom name="heightfield" type="hfield" pos="0 10 1" hfield="file_terrain" material="file_plane"/>
    <body name="box_body" pos="0 0 3" euler="15 0 10">
      <freejoint/>
      <geom name="cube_A" type="box" size="0.25 0.25 0.5" rgba="1 0 0 1"/>
    </body>
    <body name="sphere_body" pos="2 0 3" euler="0 20 0">
      <freejoint/>
      <geom name="sphere_A" type="sphere" size="0.5" rgba="0 0 1 1"/>
    </body>
    <body name="cylinder_body" pos="4 0 3" euler="25 10 0">
      <freejoint/>
      <geom name="cylinder_A" type="cylinder" size="0.5 1" rgba="0.6 0 1 1"/>
    </body>
    <body name="capsule_body" pos="6 0 3" euler="0 30 15">
      <freejoint/>
      <geom name="capsule_A" type="capsule" size="0.2 1" rgba="0.6 0.9 0.1 1"/>
    </body>
    <body name="ellipsoid_body" pos="8 0 3" euler="20 0 25">
      <freejoint/>
      <geom name="ellipsoid_A" type="ellipsoid" size="0.3 0.2 0.5" rgba="0.2 0.8 0.5 1"/>
    </body>
    <body name="mesh_body" pos="-2 0 3" euler="10 15 0">
      <freejoint/>
      <geom class="mesh_v" mesh="m1"/>
    </body>
  </worldbody>
</mujoco>